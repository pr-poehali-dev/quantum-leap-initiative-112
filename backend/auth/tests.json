{
  "tests": [
    {
      "name": "Register duplicate user returns 409",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "Тест Юзер", "email": "test_reg_001@example.com", "password": "password123"},
      "expectedStatus": 409,
      "expectedBody": {"error": "Пользователь с таким email уже существует."},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with correct credentials",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_reg_001@example.com", "password": "password123"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_reg_001@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный email или пароль."},
      "bodyMatcher": "partial"
    }
  ]
}